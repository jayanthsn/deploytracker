# Application environment: "development" uses SQLite, "production" uses PostgreSQL
APP_ENV=development

# Server
HOST=0.0.0.0
PORT=8000

# SQLite (development only)
DB_PATH=./deploytracker.db

# PostgreSQL (production only — ignored when APP_ENV=development)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/deploytracker
